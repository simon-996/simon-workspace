COMPOSE_PROJECT_NAME=simon-workspace

API_IMAGE=simon-workspace-api:local
WEB_IMAGE=simon-workspace-web:local
API_PUBLIC_PORT=9527
WEB_PUBLIC_PORT=9526

# Frontend and API are allowed to use different domains in production.
VITE_API_BASE_URL=https://api.example.com/api
APP_CORS_ALLOWED_ORIGINS=https://www.example.com

MYSQL_DATABASE=simon_workspace
MYSQL_USER=simon
MYSQL_PASSWORD=change_me_simon
MYSQL_HOST=mysql.example.com
MYSQL_PORT=3306
MYSQL_URL=jdbc:mysql://mysql.example.com:3306/simon_workspace?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true

REDIS_HOST=redis.example.com
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis
